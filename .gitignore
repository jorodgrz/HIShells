# Pipeline outputs (plan §6 / §11). Keep the directory skeleton (the
# .gitkeep markers) so a fresh clone can run scripts/train_logo.py and
# scripts/run_baseline.py without manually `mkdir`-ing first.
results/*
!results/.gitkeep
!results/checkpoints/
results/checkpoints/*
!results/checkpoints/.gitkeep

